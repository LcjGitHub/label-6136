# ============================================
# 老式收银机按键音样本库 - 环境变量配置
# ============================================
# 使用说明：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 根据实际需要修改下方配置项
#   3. .env 文件已被 .gitignore 忽略，不会提交到仓库

# --------------------------------------------
# 后端配置
# --------------------------------------------

# 后端服务端口（默认 8000）
PORT=8000

# 前端构建产物目录（生产部署时后端提供静态文件服务）
# 默认指向 frontend/dist，一般无需修改
FRONTEND_DIST=frontend/dist

# --------------------------------------------
# 前端配置（Vite 开发服务器）
# --------------------------------------------

# 前端开发服务器端口（默认 8101）
VITE_PORT=8101

# API 代理目标地址（前端开发时将 /api 请求代理至此地址）
VITE_API_TARGET=http://localhost:8000
